{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/[...path].ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/|assets/|favicon|.*\\.[a-z0-9]+$).*)", "destination": "/index.html" }
  ]
}
