# =================================================================
# PPKPT FASILKOM UNSRI — Environment Variables
# Copy ke .env.local untuk dev, set di Vercel Dashboard untuk produksi.
# =================================================================

# Supabase project URL — dari Project Settings → API → Project URL
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Supabase service role key (SECRET!) — dari Project Settings → API → service_role
# JANGAN expose ke frontend. Hanya dipakai di server / serverless function.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI..."

# AES-256 encryption key untuk data sensitif pelapor/korban di DB.
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="ganti-dengan-string-acak-32-byte-hex"

# Port untuk dev server lokal (opsional, default 3000)
PORT=3000
